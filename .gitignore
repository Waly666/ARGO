# Dependencias
node_modules/
**/node_modules/

# Variables de entorno (secretos)
.env
**/.env
.env.*

# Build / caché
argo-frontend/dist/
argo-frontend/.angular/
**/dist/
*.log

# Subidas locales (certificados, firmas, recibos)
argo-backend/uploads/*
!argo-backend/uploads/.gitkeep

# Sistema
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Cursor / assets temporales de chat (opcional; no incluir assets/ del móvil)
/assets/
!.gitkeep
.cursor/

# Sitio marketing: videos pesados (subir manualmente al VPS o usar CDN)
argo-sitio/public/videos/*.mp4
argo-sitio/public/imagenes/*.mp4

# Backup local Mongo (no subir a Git)
backup-argo.zip
backup-argo/
