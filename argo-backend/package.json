{
  "name": "argo-backend",
  "version": "1.0.0",
  "private": true,
  "description": "ARGO — API backend MEAN (Node/Express/Mongo/JWT)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node scripts/seed.js",
    "seed:users": "node scripts/seedAdmin.js",
    "seed:catalogos": "node scripts/seedCatalogosBase.js",
    "seed:config": "node scripts/seedConfig.js",
    "migrate:numdoc": "node scripts/migrateNumDocToNumber.js",
    "migrate:tipo-alumno": "node scripts/migrateTipoAlumno.js",
    "migrate:tipo-certificado": "node scripts/migrateTipoCertificado.js",
    "migrate:id-jornada-cert": "node scripts/migrarIdJornadaCertificados.js",
    "sync:consecutivo-cert": "node scripts/syncConsecutivoCertificado.js",
    "import:administradoras": "node scripts/importAdministradoras.js",
    "import:alumnos-csv": "node scripts/importAlumnosCsv.js",
    "cea:completar-faltantes": "node scripts/completarCeaAutoTodos.js",
    "cea:completar-faltantes:dry": "node scripts/completarCeaAutoTodos.js --dry-run",
    "cea:depurar-clases": "node scripts/depurarClasesCea.js --listar",
    "cea:depurar-clases:confirmar": "node scripts/depurarClasesCea.js --confirmar --reset-matriculas",
    "jornadas:migrar-sede": "node scripts/migrarSedeJornadasCap.js --confirmar",
    "jornadas:migrar-sede:dry": "node scripts/migrarSedeJornadasCap.js --listar",
    "sede:migrar-principal": "node scripts/migrarSedePrincipal.js",
    "sede:migrar-principal:forzar": "node scripts/migrarSedePrincipal.js --forzar",
    "inspeccion:migrar-preop": "node scripts/migrarInspeccionPreop.js --listar",
    "inspeccion:migrar-preop:confirmar": "node scripts/migrarInspeccionPreop.js --confirmar",
    "inspeccion:depurar": "node scripts/depurarInspeccionPreop.js --listar",
    "inspeccion:depurar:confirmar": "node scripts/depurarInspeccionPreop.js --confirmar"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "packageManager": "pnpm@11.2.2"
}
